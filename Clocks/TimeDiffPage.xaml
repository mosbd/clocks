<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Clocks.TimeDiffPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock Text="Time Difference Calculator"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,24"/>

        <!-- City selectors -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="From" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8"/>
                <ComboBox x:Name="FromCityBox" HorizontalAlignment="Stretch"
                          SelectionChanged="FromCity_SelectionChanged"/>
                <TextBlock x:Name="FromTimeText" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0"/>
                <TextBlock x:Name="FromDateText" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="FromOffsetText" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </StackPanel>

            <FontIcon Grid.Column="1" Glyph="&#xE8AB;" FontSize="24" VerticalAlignment="Center"
                      Margin="24,30,24,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <StackPanel Grid.Column="2">
                <TextBlock Text="To" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8"/>
                <ComboBox x:Name="ToCityBox" HorizontalAlignment="Stretch"
                          SelectionChanged="ToCity_SelectionChanged"/>
                <TextBlock x:Name="ToTimeText" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0"/>
                <TextBlock x:Name="ToDateText" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="ToOffsetText" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Result card -->
        <Border Grid.Row="2" CornerRadius="8" Padding="24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1" Margin="0,8,0,0"
                Visibility="Collapsed" x:Name="ResultCard">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock x:Name="DiffResultText" Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="DiffDetailText" Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
