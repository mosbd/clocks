<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Clocks.MeetingPlannerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*">
        <TextBlock Text="Meeting Planner"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,16"/>

        <!-- Business hours config -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16"
                    VerticalAlignment="Bottom">
            <TextBlock Text="Business hours:" VerticalAlignment="Bottom" Margin="0,0,0,12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <NumberBox x:Name="StartHourBox" Value="9" Minimum="0" Maximum="23"
                       SpinButtonPlacementMode="Compact" Width="110"
                       Header="Start" ValueChanged="BusinessHours_Changed"/>
            <TextBlock Text="to" VerticalAlignment="Bottom" Margin="0,0,0,12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <NumberBox x:Name="EndHourBox" Value="17" Minimum="0" Maximum="23"
                       SpinButtonPlacementMode="Compact" Width="110"
                       Header="End" ValueChanged="BusinessHours_Changed"/>
        </StackPanel>

        <!-- Timeline area -->
        <ScrollViewer Grid.Row="2">
            <StackPanel x:Name="TimelinePanel" Spacing="8"/>
        </ScrollViewer>
    </Grid>
</Page>
